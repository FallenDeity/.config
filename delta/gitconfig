# Delta-focused Git settings (included from global ~/.gitconfig)

[include]
    path = ~/.config/delta/themes/catppuccin.gitconfig

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    features = catppuccin-mocha
    navigate = true
    line-numbers = true
    side-by-side = true
    hyperlinks = true
    true-color = always

[merge]
    conflictstyle = zdiff3

